import { motion } from 'framer-motion';
import { Lesson } from '@/types';

interface PathMapProps {
  lessons: Lesson[];
  currentLevel: number;
  completedIds: string[];
  onSelect: (id: string) => void;
}

export default function PathMap({ lessons, currentLevel, completedIds, onSelect }: PathMapProps) {
  return (
    <div className="flex flex-col items-center space-y-4">
      {lessons.map((lesson, index) => {
        const isUnlocked = lesson.unlockLevel <= currentLevel;
        const isCompleted = completedIds.includes(lesson.id);
        return (
          <motion.div
            key={lesson.id}
            className={`w-full max-w-xs p-4 rounded-2xl shadow-md cursor-pointer ${
              isCompleted ? 'bg-green-100 border-2 border-green-500' :
              isUnlocked ? 'bg-blue-100 border-2 border-blue-400 hover:shadow-lg' :
              'bg-gray-200 opacity-60 cursor-not-allowed'
            }`}
            whileHover={{ scale: isUnlocked ? 1.02 : 1 }}
            onClick={() => isUnlocked && onSelect(lesson.id)}
          >
            <h3 className="font-bold text-lg">{lesson.title}</h3>
            <p className="text-sm">{isCompleted ? '✅ تم' : isUnlocked ? '🔓 مفتوح' : '🔒 مقفل'}</p>
          </motion.div>
        );
      })}
    </div>
  );
}

