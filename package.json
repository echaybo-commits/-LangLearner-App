'use client';
import { useState, useEffect } from 'react';
import { motion } from 'framer-motion';

interface ExerciseProps {
  word: string;
  correctTranslation: string;
  options: string[];
  onAnswer: (isCorrect: boolean) => void;
}

export default function Exercise({ word, correctTranslation, options, onAnswer }: ExerciseProps) {
  const [selected, setSelected] = useState<string | null>(null);
  const [shuffled, setShuffled] = useState<string[]>([]);

  useEffect(() => {
    setShuffled([...options].sort(() => Math.random() - 0.5));
    setSelected(null);
  }, [word, options]);

  const handleSelect = (choice: string) => {
    if (selected) return;
    setSelected(choice);
    const isCorrect = choice === correctTranslation;
    onAnswer(isCorrect);
  };

  return (
    <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className="bg-white p-6 rounded-2xl shadow-xl">
      <h2 className="text-xl font-bold text-center mb-2">اختر الترجمة الصحيحة</h2>
      <div className="text-3xl font-arabic text-center mb-6">{word}</div>
      <div className="grid grid-cols-2 gap-3">
        {shuffled.map((opt) => (
          <button
            key={opt}
            onClick={() => handleSelect(opt)}
            className={`p-3 rounded-xl text-lg font-medium transition ${
              selected === opt
                ? opt === correctTranslation
                  ? 'bg-green-500 text-white'
                  : 'bg-red-500 text-white'
                : 'bg-gray-100 hover:bg-gray-200'
            }`}
            disabled={!!selected}
          >
            {opt}
          </button>
        ))}
      </div>
    </motion.div>
  );
}

