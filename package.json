'use client';
import { useParams, useRouter } from 'next/navigation';
import { useUser } from '@/contexts/UserContext';
import { useState, useEffect } from 'react';
import { WordEntry } from '@/types';
import { loadCoreDictionary, lookupWord } from '@/lib/dictionary';
import Exercise from '@/components/Exercise';

// دالة مساعدة لتوليد أسئلة من قائمة الكلمات
function generateQuestions(words: string[], lang: string, targetLang: string): any[] {
  // هنا نقوم بتحويل الكلمات إلى أسئلة (اختيار من متعدد)
  // نأخذ أول 5 كلمات مثلاً
  return words.slice(0, 5).map(word => ({
    word,
    correctTranslation: word, // سنقوم باستبدالها بالترجمة الفعلية لاحقًا
    options: [word, 'خيار1', 'خيار2', 'خيار3'], // مؤقت
  }));
}

export default function LessonPage() {
  const { lang, lessonId } = useParams() as { lang: string; lessonId: string };
  const router = useRouter();
  const { progress, addXP, loseHeart, completeLesson, updateProgress } = useUser();
  const [questions, setQuestions] = useState<any[]>([]);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [score, setScore] = useState(0);
  const [finished, setFinished] = useState(false);

  // تحميل الدرس وبياناته
  useEffect(() => {
    async function loadLesson() {
      // نبحث عن الدرس في learningPaths
      const allPaths = {
        ar: [
          { id: 'ar-1', title: 'التحيات', words: ['مرحبا', 'سلام', 'شكرا'], unlockLevel: 1 },
          { id: 'ar-2', title: 'الأرقام', words: ['واحد', 'اثنان', 'ثلاثة'], unlockLevel: 2 },
        ],
        en: [
          { id: 'en-1', title: 'Greetings', words: ['hello', 'goodbye', 'thank you'], unlockLevel: 1 },
        ],
        // ... أضف الباقي
      };
      const lessons = allPaths[lang] || [];
      const lesson = lessons.find(l => l.id === lessonId);
      if (!lesson) {
        router.push(`/path/${lang}`);
        return;
      }

      // تحميل المعجم الأساسي للغة
      await loadCoreDictionary(lang);

      // بناء الأسئلة من كلمات الدرس
      const qs = await Promise.all(lesson.words.map(async (w) => {
        // البحث عن الكلمة في المعجم
        const entry = await lookupWord(w, lang, 'en'); // نستخدم الإنجليزية كهدف مؤقت، يمكن تعديله
        const correctTranslation = entry?.translations?.en || w;
        // توليد خيارات عشوائية (سنستخدم كلمات عشوائية من المعجم)
        const allWords = Object.values(coreDicts).flat(); // مبسط
        const randomOptions = allWords
          .filter(e => e.word !== w)
          .sort(() => Math.random() - 0.5)
          .slice(0, 3)
          .map(e => e.translations?.en || e.word);
        const options = [correctTranslation, ...randomOptions].sort(() => Math.random() - 0.5);
        return {
          word: w,
          correctTranslation,
          options,
        };
      }));

      setQuestions(qs);
    }
    loadLesson();
  }, [lang, lessonId, router]);

  const handleAnswer = (isCorrect: boolean) => {
    if (isCorrect) {
      addXP(10);
      setScore(prev => prev + 1);
    } else {
      loseHeart();
    }

    // الانتقال للسؤال التالي أو النهاية
    if (currentIndex + 1 < questions.length) {
      setCurrentIndex(prev => prev + 1);
    } else {
      setFinished(true);
      // إكمال الدرس
      completeLesson(lessonId);
      // تحديث الكلمات المتعلمة (نضيف كلمات الدرس)
      const lessonWords = questions.map(q => q.word);
      updateProgress(p => ({
        ...p,
        learnedWords: [...new Set([...p.learnedWords, ...lessonWords])],
      }));
    }
  };

  if (finished) {
    return (
      <div className="p-6 max-w-md mx-auto text-center">
        <h2 className="text-2xl font-bold mb-4">🎉 انتهى الدرس!</h2>
        <p className="text-lg">الإجابات الصحيحة: {score} من {questions.length}</p>
        <p className="text-lg">+{score * 10} نقطة خبرة</p>
        <button
          onClick={() => router.push(`/path/${lang}`)}
          className="mt-6 bg-blue-600 text-white px-6 py-3 rounded-full shadow-lg"
        >
          العودة إلى المسار
        </button>
      </div>
    );
  }

  if (questions.length === 0) {
    return <div className="p-6 text-center">جاري تحميل الدرس...</div>;
  }

  const currentQ = questions[currentIndex];
  return (
    <div className="p-4 max-w-md mx-auto">
      <div className="flex justify-between mb-4">
        <span>❤️ {progress.hearts}</span>
        <span>XP {progress.xp}</span>
        <span>المستوى {progress.level}</span>
      </div>
      <Exercise
        word={currentQ.word}
        correctTranslation={currentQ.correctTranslation}
        options={currentQ.options}
        onAnswer={handleAnswer}
      />
      <p className="text-center text-sm text-gray-500 mt-4">{currentIndex+1} / {questions.length}</p>
    </div>
  );
}

